---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { fetchReleaseStatus } from "../lib/github";
import { loadLatestManifest } from "../lib/latest";

const gh = await fetchReleaseStatus();
const manifest = loadLatestManifest();
---

<Layout title="Estado del release — Paraguacraft" description="Última versión publicada en GitHub Releases y manifest latest.json.">
  <Nav />

  <main class="py-16 md:py-24">
    <div class="container-page max-w-3xl">
      <div class="reveal mb-10">
        <span class="badge border border-brand-400/30 bg-brand-400/10 text-brand-300">Status</span>
        <h1 class="mt-4 text-4xl font-black">Estado del release</h1>
        <p class="mt-4 text-gray-400">Comparación entre GitHub Releases y el manifest servido por la web.</p>
      </div>

      <div class="reveal space-y-4">
        <article class="card">
          <h2 class="font-bold text-white">GitHub Releases (latest)</h2>
          {gh ? (
            <ul class="mt-4 space-y-2 text-sm text-gray-400">
              <li><span class="text-gray-500">Tag:</span> <span class="font-mono text-white">{gh.tag}</span></li>
              <li><span class="text-gray-500">Nombre:</span> {gh.name}</li>
              <li><span class="text-gray-500">Publicado:</span> {new Date(gh.publishedAt).toLocaleString("es-AR")}</li>
              <li>
                <span class="text-gray-500">Instalador:</span>{" "}
                {gh.downloadUrl ? (
                  <a href={gh.downloadUrl} class="text-brand-300 hover:underline break-all">{gh.downloadUrl}</a>
                ) : (
                  <span class="text-amber-400">No se encontró .exe en el release</span>
                )}
              </li>
              <li><a href={gh.htmlUrl} target="_blank" rel="noopener" class="text-brand-300 hover:underline">Abrir en GitHub →</a></li>
            </ul>
          ) : (
            <p class="mt-4 text-amber-400 text-sm">No se pudo consultar la API de GitHub en el build. Revisá manualmente en Releases.</p>
          )}
        </article>

        <article class="card">
          <h2 class="font-bold text-white">latest.json (web / updater)</h2>
          <ul class="mt-4 space-y-2 text-sm text-gray-400">
            <li><span class="text-gray-500">Versión:</span> <span class="font-mono text-white">v{manifest.version}</span></li>
            <li><span class="text-gray-500">SHA-256:</span> <span class="font-mono text-xs break-all text-brand-300">{manifest.sha256 ?? "—"}</span></li>
            <li><span class="text-gray-500">URL:</span> <a href={manifest.download_url} class="text-brand-300 hover:underline break-all">{manifest.download_url}</a></li>
          </ul>
        </article>

        {gh && gh.tag.replace(/^v/, "") === manifest.version && (
          <p class="text-sm text-brand-300">✓ Versión de GitHub y latest.json coinciden.</p>
        )}
        {gh && gh.tag.replace(/^v/, "") !== manifest.version && (
          <p class="text-sm text-amber-400">⚠ Desincronización: GitHub {gh.tag} vs manifest v{manifest.version}. Actualizá public/latest.json.</p>
        )}
      </div>

      <a href="/" class="reveal mt-8 inline-block text-sm text-gray-400 hover:text-white">← Volver al inicio</a>
    </div>
  </main>

  <Footer />
</Layout>
