---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import StatusBanner from "../components/StatusBanner.astro";
import WhatsNew from "../components/WhatsNew.astro";
import HowToStart from "../components/HowToStart.astro";
import Features from "../components/Features.astro";
import PvpClient from "../components/PvpClient.astro";
import Gallery from "../components/Gallery.astro";
import Stats from "../components/Stats.astro";
import Compare from "../components/Compare.astro";
import Requirements from "../components/Requirements.astro";
import Changelog from "../components/Changelog.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Nav />
  <StatusBanner />
  <Hero />
  <WhatsNew />
  <HowToStart />
  <Features />
  <PvpClient />
  <Gallery />
  <Stats />
  <Compare />
  <Requirements />
  <Changelog />

  <section class="py-20">
    <div class="container-page">
      <div class="reveal rounded-3xl border border-pc-green/25 bg-gradient-to-br from-pc-green/10 via-transparent to-pc-purple/10 p-10 text-center md:p-14">
        <h2 class="text-2xl font-black md:text-3xl">Listo para jugar sin lag del launcher</h2>
        <p class="mx-auto mt-4 max-w-lg text-gray-400">
          Descargá la última versión — instalador Windows, auto-update y verificación SHA-256.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/download" class="btn-primary px-8 py-3.5">Descargar gratis</a>
          <a href="/notas" class="btn-secondary">Ver novedades</a>
        </div>
      </div>
    </div>
  </section>

  <FAQ />
  <Footer />
</Layout>
