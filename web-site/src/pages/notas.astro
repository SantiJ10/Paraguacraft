---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { loadChangelog, inlineMd } from "../lib/changelog";

const entries = loadChangelog(12);
---

<Layout title="Notas de versión — Paraguacraft" description="Historial de cambios del launcher Paraguacraft.">
  <Nav />

  <main class="py-16 md:py-24">
    <div class="container-page max-w-3xl">
      <div class="reveal mb-12">
        <span class="badge border border-brand-400/30 bg-brand-400/10 text-brand-300">Blog / Parches</span>
        <h1 class="mt-4 text-4xl font-black md:text-5xl">Notas de versión</h1>
        <p class="mt-4 text-gray-400">Qué cambió en cada release del launcher.</p>
      </div>

      <div class="space-y-8">
        {entries.map((e) => (
          <article class="reveal card">
            <header class="mb-4 flex flex-wrap items-baseline gap-3 border-b border-bg-border pb-4">
              <h2 class="text-2xl font-black text-white">v{e.version}</h2>
              <time class="text-sm text-gray-500">{e.date}</time>
              <a
                href={`https://github.com/SantiJ10/Paraguacraft/releases/tag/v${e.version}`}
                target="_blank"
                rel="noopener"
                class="ml-auto text-xs text-brand-300 hover:underline"
              >
                Release →
              </a>
            </header>
            {e.sections.map((sec) => (
              <div class="mb-4 last:mb-0">
                <h3 class="mb-2 text-xs font-black uppercase tracking-widest text-brand-400">{sec.heading}</h3>
                <ul class="space-y-2">
                  {sec.items.map((it) => (
                    <li class="flex gap-2 text-sm text-gray-300 leading-relaxed">
                      <span class="text-brand-400">▸</span>
                      <span set:html={inlineMd(it)} />
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </article>
        ))}
      </div>

      <div class="reveal mt-12 text-center">
        <a href="https://github.com/SantiJ10/Paraguacraft/blob/main/CHANGELOG.md" target="_blank" rel="noopener" class="btn-secondary">
          Changelog completo en GitHub →
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
