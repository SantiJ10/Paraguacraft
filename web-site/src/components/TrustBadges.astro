---
import { loadLatestManifest, formatSize } from "../lib/latest";

const latest = loadLatestManifest();
const sizeLabel = formatSize(latest.size_bytes);

const badges = [
  { icon: "🛡️", label: "SHA-256 verificable", detail: "Hash publicado en latest.json" },
  { icon: "💻", label: "Windows 10 / 11", detail: "64-bit · instalador NSIS" },
  ...(sizeLabel ? [{ icon: "📦", label: sizeLabel, detail: `Instalador v${latest.version}` }] : []),
  { icon: "🔄", label: "Auto-update", detail: "Actualizaciones desde GitHub Releases" },
];
---

<div class="flex flex-wrap gap-3">
  {
    badges.map((b) => (
      <div class="flex items-center gap-2.5 rounded-xl border border-bg-border bg-bg-soft/80 px-4 py-2.5 text-sm">
        <span class="text-lg" aria-hidden="true">{b.icon}</span>
        <div>
          <p class="font-bold text-fg leading-tight">{b.label}</p>
          <p class="text-xs text-gray-500">{b.detail}</p>
        </div>
      </div>
    ))
  }
</div>
