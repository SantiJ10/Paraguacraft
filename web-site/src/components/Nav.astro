---
const links = [
  { href: "/#howtostart", label: "Empezar" },
  { href: "/#features", label: "Features" },
  { href: "/#pvp", label: "Cliente PvP" },
  { href: "/#gallery", label: "Capturas" },
  { href: "/#compare", label: "Comparativa" },
  { href: "/notas", label: "Notas" },
  { href: "/#faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-50 border-b border-bg-border bg-bg/80 backdrop-blur-md">
  <nav class="container-page flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-3">
      <img src="/icon.png" alt="Paraguacraft" class="h-9 w-9 rounded-lg shadow-glow-sm" />
      <span class="text-sm font-black tracking-wide text-fg sm:text-base">Paraguacraft</span>
    </a>

    <div class="hidden items-center gap-1 lg:flex">
      {links.map((l) => (
        <a href={l.href} class="btn-ghost text-sm">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Cambiar tema claro/oscuro"
        class="hidden h-10 w-10 items-center justify-center rounded-lg text-fg-muted transition hover:bg-bg-hover hover:text-fg sm:inline-flex"
      >
        <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <button
        id="nav-toggle"
        aria-label="Abrir menú"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-fg-muted transition hover:bg-bg-hover hover:text-fg lg:hidden"
      >
        <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <a href="/download" class="btn-primary hidden py-2 px-4 text-sm sm:inline-flex">Descargar</a>
    </div>
  </nav>

  <div id="nav-mobile" class="hidden border-t border-bg-border bg-bg/95 backdrop-blur-md lg:hidden">
    <div class="container-page flex flex-col gap-1 py-4">
      {links.map((l) => (
        <a href={l.href} class="nav-mobile-link rounded-lg px-3 py-3 text-sm font-semibold text-fg-secondary transition hover:bg-bg-hover hover:text-fg">{l.label}</a>
      ))}
      <a href="/download" class="btn-primary mt-2 py-2.5 text-center text-sm">Descargar</a>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var toggle = document.getElementById("theme-toggle");
    var moon = document.getElementById("icon-moon");
    var sun = document.getElementById("icon-sun");

    function syncThemeIcons() {
      var light = root.getAttribute("data-theme") === "light";
      if (moon) moon.classList.toggle("hidden", light);
      if (sun) sun.classList.toggle("hidden", !light);
    }
    syncThemeIcons();

    if (toggle) {
      toggle.addEventListener("click", function () {
        var next = root.getAttribute("data-theme") === "light" ? "dark" : "light";
        root.setAttribute("data-theme", next);
        try { localStorage.setItem("pc-theme", next); } catch (_) {}
        syncThemeIcons();
      });
    }

    var navToggle = document.getElementById("nav-toggle");
    var menu = document.getElementById("nav-mobile");
    var iconOpen = document.getElementById("icon-open");
    var iconClose = document.getElementById("icon-close");
    if (navToggle && menu) {
      navToggle.addEventListener("click", function () {
        var hidden = menu.classList.toggle("hidden");
        if (iconOpen) iconOpen.classList.toggle("hidden", !hidden);
        if (iconClose) iconClose.classList.toggle("hidden", hidden);
      });
      menu.querySelectorAll("a").forEach(function (a) {
        a.addEventListener("click", function () {
          menu.classList.add("hidden");
          if (iconOpen) iconOpen.classList.remove("hidden");
          if (iconClose) iconClose.classList.add("hidden");
        });
      });
    }
  })();
</script>
