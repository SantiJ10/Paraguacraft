---
import { fetchReleaseStatus } from "../lib/github";
import { loadLatestManifest } from "../lib/latest";

const gh = await fetchReleaseStatus();
const manifest = loadLatestManifest();

const tag = gh?.tag?.replace(/^v/, "") ?? manifest.version;
const published = gh?.publishedAt
  ? new Date(gh.publishedAt).toLocaleDateString("es-AR", {
      day: "numeric",
      month: "short",
      year: "numeric",
    })
  : null;
---

<section class="border-b border-bg-border bg-bg-card/60">
  <div class="container-page flex flex-col gap-3 py-3 text-sm md:flex-row md:items-center md:justify-between">
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-brand-400/30 bg-brand-400/10 px-2.5 py-0.5 text-xs font-bold text-brand-300">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        Último release
      </span>
      <span class="font-bold text-fg">v{tag}</span>
      {published && <span class="text-gray-500">· publicado {published}</span>}
      {!gh && <span class="text-gray-500">· manifest local v{manifest.version}</span>}
    </div>
    <div class="flex flex-wrap gap-4 text-gray-400">
      <a href="/status" class="hover:text-brand-300 transition">Estado del release →</a>
      <a href="https://github.com/SantiJ10/Paraguacraft/releases" target="_blank" rel="noopener" class="hover:text-brand-300 transition">GitHub Releases →</a>
    </div>
  </div>
</section>
