---
import { loadLatestManifest } from "../lib/latest";
import TrustBadges from "./TrustBadges.astro";

const latest = loadLatestManifest();
---

<section id="hero" class="relative overflow-hidden pb-20 pt-10 md:pb-28 md:pt-14">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <img
      src="/banner.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-[center_20%] opacity-[0.14]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/95 to-bg/80 dark:from-pc-dark dark:via-pc-dark/95 dark:to-pc-dark/70"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-bg/50 dark:from-pc-dark dark:via-transparent dark:to-pc-dark/40"></div>
    <div class="absolute -left-32 top-0 h-96 w-96 rounded-full bg-pc-green/10 blur-3xl"></div>
    <div class="absolute -right-24 top-20 h-80 w-80 rounded-full bg-pc-purple/10 blur-3xl"></div>
  </div>

  <div class="container-page relative z-10 grid items-center gap-12 lg:grid-cols-2">
    <div class="animate-fade-up space-y-6">
      <div class="inline-flex items-center gap-2 rounded-full border border-pc-green/30 bg-pc-green/10 px-3 py-1 text-xs font-semibold text-pc-green">
        <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-pc-green"></span>
        v{latest.version} — Tauri v2 + Rust + Vue 3
      </div>

      <h1 class="text-4xl font-black leading-[1.05] tracking-tight md:text-5xl lg:text-6xl">
        Rendimiento extremo.<br />
        <span class="text-gradient">Cero compromiso.</span>
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-fg-muted">
        Paraguacraft no compite con tu FPS. <strong class="text-fg">0% de CPU en segundo plano</strong> mientras jugás,
        tienda Modrinth + CurseForge, modpacks, servidores Playit.gg y diagnóstico con IA — todo en <strong class="text-fg">Rust</strong>.
      </p>

      <div id="download" class="space-y-4 pt-2">
        <div class="flex flex-wrap items-center gap-4">
          <a
            id="download-btn"
            href={latest.download_url}
            class="animate-pulse-glow inline-flex items-center gap-2 rounded-xl bg-pc-green px-6 py-3.5 text-base font-black text-black transition hover:scale-[1.02] hover:brightness-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 16l-5-5h3V4h4v7h3l-5 5zm-7 4h14v-2H5v2z" />
            </svg>
            <span id="download-label">Descargar v{latest.version}</span>
          </a>
          <a href="/download" class="btn-secondary">Ver hash SHA-256 →</a>
        </div>
        <p id="download-meta" class="text-sm text-gray-500">
          Windows 10/11 · Actualizable
        </p>
        <p id="download-error" class="hidden text-sm text-amber-400"></p>
        <TrustBadges />
      </div>
    </div>

    <div class="animate-fade-up relative lg:pl-8" style="animation-delay: 0.15s">
      <div class="glass animate-float overflow-hidden rounded-2xl border-pc-green/20 p-1 shadow-2xl shadow-pc-green/5">
        <div class="rounded-xl bg-[#0D0D0F] p-4">
          <div class="mb-4 flex items-center gap-2 border-b border-pc-border pb-3">
            <img src="/icon.png" alt="" class="h-6 w-6 rounded-md" />
            <span class="text-sm font-semibold">Paraguacraft Launcher</span>
            <span class="ml-auto rounded bg-pc-green/20 px-2 py-0.5 text-[10px] font-bold text-pc-green">TAURI</span>
          </div>
          <div class="space-y-3 font-mono text-xs">
            <div class="flex justify-between text-gray-500">
              <span>CPU idle (jugando)</span>
              <span class="font-bold text-pc-green">0.0%</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-pc-border">
              <div class="h-full w-[2%] rounded-full bg-pc-green"></div>
            </div>
            <div class="flex justify-between text-gray-500">
              <span>Modpack CurseForge .zip</span>
              <span class="text-white">Importado ✓</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-pc-border">
              <div class="h-full w-[65%] rounded-full bg-gradient-to-r from-pc-green to-pc-purple"></div>
            </div>
            <div class="rounded-lg border border-pc-purple/30 bg-pc-purple/10 p-3 text-gray-300">
              <span class="text-pc-purple">✦ Favoritos</span> Join directo al servidor del grupo
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function loadLatestManifest() {
    const btn = document.getElementById("download-btn");
    const label = document.getElementById("download-label");
    const meta = document.getElementById("download-meta");
    const errEl = document.getElementById("download-error");
    if (!btn || !label) return;

    try {
      const res = await fetch("/latest.json", { cache: "no-store" });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const version = data.version || "7.0.2";
      if (data.download_url) btn.setAttribute("href", data.download_url);
      label.textContent = `Descargar v${version}`;
      if (meta) {
        const mb = data.size_bytes ? (Number(data.size_bytes) / (1024 * 1024)).toFixed(1) : null;
        meta.textContent = mb ? `Windows 10/11 · v${version} · ${mb} MB` : `Windows 10/11 · v${version}`;
      }
    } catch (e) {
      if (errEl) {
        errEl.textContent = "No se pudo refrescar latest.json — usando datos embebidos.";
        errEl.classList.remove("hidden");
      }
      console.warn("[Paraguacraft] latest.json:", e);
    }
  }
  loadLatestManifest();
</script>
