---
const reqs = [
  {
    icon: '<rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="8 21 12 17 16 21"/>',
    title: 'Sistema operativo',
    value: 'Windows 10 / 11',
    detail: '64-bit · Home, Pro y LTSC',
  },
  {
    icon: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="2" x2="9" y2="4"/><line x1="15" y1="2" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="22"/><line x1="15" y1="20" x2="15" y2="22"/><line x1="2" y1="9" x2="4" y2="9"/><line x1="2" y1="15" x2="4" y2="15"/><line x1="20" y1="9" x2="22" y2="9"/><line x1="20" y1="15" x2="22" y2="15"/>',
    title: 'RAM',
    value: '4 GB mínimo',
    detail: '8 GB recomendado para mods',
  },
  {
    icon: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>',
    title: 'Espacio en disco',
    value: '500 MB+',
    detail: 'Launcher 200 MB · Minecraft y mods aparte',
  },
  {
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    title: 'Internet',
    value: 'Requerido',
    detail: 'Para descargar Minecraft y para cuentas premium',
  },
  {
    icon: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>',
    title: 'Java',
    value: 'Automático',
    detail: 'El launcher descarga e instala Java si no lo tenés',
  },
  {
    icon: '<path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>',
    title: 'WebView2',
    value: 'Automático',
    detail: 'Se descarga solo si no está instalado',
  },
];
---

<section id="requirements" class="py-20 lg:py-24 relative">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-bg-border to-transparent"></div>

  <div class="container-page">
    <div class="reveal max-w-xl mb-12">
      <span class="badge bg-brand-400/10 border border-brand-400/30 text-brand-300 mb-4">Requisitos</span>
      <h2 class="text-4xl sm:text-5xl font-black tracking-tight mb-4">
        ¿Corre en <span class="gradient-text">tu PC?</span>
      </h2>
      <p class="text-fg-muted">
        Casi seguro que sí. El launcher es ligero y maneja las dependencias solo.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {reqs.map((r, i) => (
        <div class="reveal flex items-start gap-4 card" style={`transition-delay:${i * 60}ms`}>
          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-brand-400/10 border border-brand-400/20 flex items-center justify-center mt-0.5">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-300" set:html={r.icon} />
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-widest font-bold text-gray-500 mb-0.5">{r.title}</p>
            <p class="font-bold text-fg text-base leading-tight">{r.value}</p>
            <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{r.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
