---
const tabs = [
  { label: "Inicio", src: "/screenshots/inicio.png", desc: "Home, favoritos y jugado reciente" },
  { label: "Instancias", src: "/screenshots/instancias.png", desc: "Perfiles, modpacks e importación" },
  { label: "Tienda", src: "/screenshots/tienda.png", desc: "Modrinth + CurseForge integrados" },
  { label: "Skins", src: "/screenshots/skins.png", desc: "Catálogo MineSkin e importación" },
  { label: "Versiones", src: "/screenshots/versiones.png", desc: "Vanilla, Fabric, Forge e Iris" },
  { label: "Servidores", src: "/screenshots/servidores.png", desc: "Paper local, consola y Playit.gg" },
];
---

<section id="gallery" class="py-24 lg:py-32 relative overflow-hidden">
  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 h-[600px] bg-radial-fade opacity-30 pointer-events-none -z-10"></div>

  <div class="container-page">
    <div class="reveal max-w-2xl mb-12">
      <span class="badge bg-brand-400/10 border border-brand-400/30 text-brand-300 mb-4">Capturas</span>
      <h2 class="text-4xl sm:text-5xl font-black tracking-tight mb-4">
        Velo en <span class="gradient-text">acción.</span>
      </h2>
      <p class="text-lg text-gray-400">
        Capturas reales del launcher v7.0.2 — cada sección principal del menú.
      </p>
    </div>

    <div class="reveal flex flex-wrap gap-2 mb-6" id="gallery-tabs">
      {tabs.map((t, i) => (
        <button
          type="button"
          class:list={[
            "gallery-tab rounded-lg border px-4 py-2 text-sm font-semibold transition",
            i === 0
              ? "border-brand-400/40 bg-brand-400/15 text-brand-300"
              : "border-bg-border bg-bg-card text-gray-400 hover:border-brand-400/30 hover:text-white",
          ]}
          data-index={i}
        >
          {t.label}
        </button>
      ))}
    </div>

    <div class="reveal relative">
      <div class="pointer-events-none absolute -inset-8 animate-float rounded-full bg-brand-400/10 opacity-50 blur-3xl"></div>
      <div class="relative mx-auto max-w-6xl overflow-hidden rounded-2xl border border-bg-border bg-bg-card shadow-2xl shadow-brand-400/5">
        <div class="flex items-center gap-1.5 border-b border-bg-border bg-bg-soft px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-[#FF5F57]"></div>
          <div class="h-3 w-3 rounded-full bg-[#FEBC2E]"></div>
          <div class="h-3 w-3 rounded-full bg-[#28C840]"></div>
          <span class="ml-3 font-mono text-xs text-gray-500" id="gallery-label">Paraguacraft · Inicio</span>
        </div>

        <div class="relative bg-[#0a0a0b]" id="gallery-viewer">
          {tabs.map((t, i) => (
            <img
              src={t.src}
              alt={`Paraguacraft — ${t.label}`}
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              class:list={[
                "gallery-slide block w-full h-auto transition-opacity duration-300",
                i === 0 ? "opacity-100" : "hidden opacity-0",
              ]}
              data-index={i}
              data-label={`Paraguacraft · ${t.label}`}
            />
          ))}
        </div>
      </div>
    </div>

    <div class="reveal mt-6 flex flex-wrap justify-center gap-3" id="gallery-thumbs">
      {tabs.map((t, i) => (
        <button
          type="button"
          class:list={[
            "gallery-thumb h-16 w-28 overflow-hidden rounded-lg border-2 transition sm:h-20 sm:w-36",
            i === 0 ? "border-brand-400 opacity-100" : "border-transparent opacity-50 hover:opacity-80",
          ]}
          data-index={i}
          aria-label={t.label}
        >
          <img src={t.src} alt={t.label} class="h-full w-full object-cover object-top" loading="lazy" />
        </button>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var current = 0;
    var tabs = document.querySelectorAll(".gallery-tab");
    var slides = document.querySelectorAll(".gallery-slide");
    var thumbs = document.querySelectorAll(".gallery-thumb");
    var label = document.getElementById("gallery-label");

    function goTo(idx) {
      if (idx === current) return;
      slides[current].classList.add("hidden");
      slides[current].classList.remove("opacity-100");
      slides[idx].classList.remove("hidden");
      setTimeout(function () { slides[idx].classList.add("opacity-100"); }, 10);
      tabs[current].classList.remove("border-brand-400/40", "bg-brand-400/15", "text-brand-300");
      tabs[current].classList.add("border-bg-border", "bg-bg-card", "text-gray-400");
      tabs[idx].classList.add("border-brand-400/40", "bg-brand-400/15", "text-brand-300");
      tabs[idx].classList.remove("border-bg-border", "bg-bg-card", "text-gray-400");
      if (thumbs.length) {
        thumbs[current].classList.remove("border-brand-400", "opacity-100");
        thumbs[current].classList.add("border-transparent", "opacity-50");
        thumbs[idx].classList.add("border-brand-400", "opacity-100");
        thumbs[idx].classList.remove("border-transparent", "opacity-50");
      }
      if (label) label.textContent = slides[idx].dataset.label || "";
      current = idx;
    }

    tabs.forEach(function (btn) {
      btn.addEventListener("click", function () { goTo(Number(btn.dataset.index)); });
    });
    thumbs.forEach(function (btn) {
      btn.addEventListener("click", function () { goTo(Number(btn.dataset.index)); });
    });
  })();
</script>
