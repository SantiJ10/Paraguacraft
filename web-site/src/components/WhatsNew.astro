---
import { loadLatestManifest, parseReleaseNotes } from "../lib/latest";

const latest = loadLatestManifest();
const items = parseReleaseNotes(latest.notes);
---

<section id="whats-new" class="border-y border-bg-border bg-bg-soft/40 py-16 lg:py-20">
  <div class="container-page">
    <div class="reveal mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="badge border border-brand-400/30 bg-brand-400/10 text-brand-300">Novedades</span>
        <h2 class="mt-3 text-3xl font-black md:text-4xl">
          Qué trae la <span class="gradient-text">v{latest.version}</span>
        </h2>
      </div>
      <a
        href="/notas"
        class="btn-secondary text-sm"
      >
        Ver todas las notas →
      </a>
    </div>

    <ul class="reveal grid gap-3 sm:grid-cols-2">
      {
        items.map((item) => (
          <li class="card flex gap-3 !py-4">
            <span class="mt-0.5 text-brand-400">✦</span>
            <span class="text-sm leading-relaxed text-fg-secondary">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
