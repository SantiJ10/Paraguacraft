---
const steps = [
  {
    num: '01',
    title: 'Descargá',
    desc: 'Hacé clic en el botón de descarga. Un solo archivo .exe, sin instaladores extra raros.',
    icon: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
  },
  {
    num: '02',
    title: 'Instalá',
    desc: 'Ejecutá el instalador. Si falta WebView2 o Java, el launcher los descarga e instala solo.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    num: '03',
    title: 'Jugá',
    desc: 'Iniciá sesión con tu cuenta Microsoft o en modo offline. Elegí tu versión y dale play.',
    icon: '<polygon points="5 3 19 12 5 21 5 3"/>',
  },
];
---

<section id="howtostart" class="py-20 lg:py-24 relative overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-brand-400/30 to-transparent"></div>

  <div class="container-page">
    <div class="reveal text-center max-w-xl mx-auto mb-14">
      <span class="badge bg-brand-400/10 border border-brand-400/30 text-brand-300 mb-4">Empezar</span>
      <h2 class="text-4xl sm:text-5xl font-black tracking-tight mb-4">
        Tres pasos y <span class="gradient-text">a jugar.</span>
      </h2>
      <p class="text-fg-muted">Sin complicaciones. El launcher se encarga del resto.</p>
    </div>

    <div class="relative grid md:grid-cols-3 gap-6 lg:gap-10 max-w-4xl mx-auto">
      <!-- línea conectora (solo desktop) -->
      <div class="hidden md:block absolute top-10 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-gradient-to-r from-brand-400/20 via-brand-400/50 to-brand-400/20 pointer-events-none"></div>

      {steps.map((s, i) => (
        <div class={`reveal card text-center relative`} style={`transition-delay:${i * 100}ms`}>
          <!-- número -->
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-[10px] font-black font-mono text-brand-400 bg-bg-card border border-brand-400/30 rounded-full px-2 py-0.5">
            {s.num}
          </span>
          <!-- icono -->
          <div class="w-14 h-14 mx-auto mb-5 mt-2 rounded-2xl bg-brand-400/10 border border-brand-400/20 flex items-center justify-center">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-300" set:html={s.icon} />
          </div>
          <h3 class="font-black text-fg text-2xl mb-3">{s.title}</h3>
          <p class="text-sm text-fg-muted leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-10">
      <a href="#download" class="btn-primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Descargar ahora — es gratis
      </a>
    </div>
  </div>
</section>
