---
const stats = [
  { value: "0%", label: "CPU idle al jugar", sub: "Runtime apagado por diseño" },
  { value: "12×", label: "Descargas paralelas", sub: "Motor Rust con límite inteligente" },
  { value: "SHA-1", label: "Verificación integrada", sub: "Anti-corrupción en cada archivo" },
  { value: "6+", label: "Loaders soportados", sub: "Fabric, Forge, Iris, NeoForge, Quilt, PvP" },
];

const tiers = [
  {
    name: "Gama baja",
    ram: "2–4 GB",
    desc: "Perfil lite, GC optimizado, descargas acotadas para no saturar disco ni red.",
  },
  {
    name: "Gama media",
    ram: "4–8 GB",
    desc: "Flags G1GC estilo Aikar, autodetección de Java y mods esenciales vía tienda.",
  },
  {
    name: "Gama alta",
    ram: "8–16 GB",
    desc: "ZGC/Shenandoah opcional, instancias pesadas y modpacks completos sin cuellos de botella.",
  },
];
---

<section id="stats" class="border-y border-bg-border bg-bg-soft px-6 py-24 md:px-10 lg:px-16">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="mb-3 text-sm font-bold uppercase tracking-widest text-pc-purple">Rendimiento</p>
        <h2 class="text-3xl font-black md:text-4xl">Optimización universal automática</h2>
        <p class="mt-3 max-w-xl text-fg-muted">
          Paraguacraft detecta tu hardware y aplica perfiles JVM, RAM y flags GC sin que tengas que ser experto en Java.
        </p>
      </div>
    </div>

    <div class="mb-16 grid grid-cols-2 gap-6 lg:grid-cols-4">
      {
        stats.map((s) => (
          <div class="glass rounded-2xl p-6 text-center">
            <p class="text-3xl font-black text-pc-green md:text-4xl">{s.value}</p>
            <p class="mt-2 font-semibold">{s.label}</p>
            <p class="mt-1 text-xs text-gray-500">{s.sub}</p>
          </div>
        ))
      }
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        tiers.map((t) => (
          <div class="rounded-2xl border border-bg-border bg-bg-card p-6">
            <div class="mb-3 flex items-center justify-between">
              <h3 class="font-bold">{t.name}</h3>
              <span class="rounded-full bg-pc-green/15 px-3 py-1 text-xs font-bold text-pc-green">{t.ram}</span>
            </div>
            <p class="text-sm text-fg-muted">{t.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
