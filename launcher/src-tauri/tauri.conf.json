{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paraguacraft",
  "version": "1.1.3",
  "identifier": "gg.paraguacraft.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Paraguacraft Launcher",
        "width": 1180,
        "height": 740,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBNUVFMzc3MDY0QTBEQTgKUldTb0RVb0dkK05ldXNSbWdraDhHMnhOaCtQS1hDOURJOGE3NWFDNlFVM1ZZenhRVUlsaVMxeGQK",
      "endpoints": [
        "https://github.com/SantiJ10/Paraguacraft/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/hooks.nsh"
      }
    },
    "resources": {
      "resources/bundled/pvp/": "bundled/pvp/",
      "resources/bundled/pvp-modern/": "bundled/pvp-modern/"
    }
  }
}
